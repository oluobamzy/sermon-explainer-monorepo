# ============================================================
# SERMON EXPLAINER - Environment Variables Template
# ============================================================
# HOW TO USE THIS FILE:
# 1. Make a copy of this file and rename the copy to exactly:  .env
# 2. Paste your real keys into the .env copy (never into this file)
# 3. Never share, commit, or upload the .env file anywhere.
#    This .example file is safe to share - it has no real secrets.
# ============================================================

# From platform.openai.com -> API Keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From console.anthropic.com -> API Keys
# (Different login than claude.ai - this is the developer console)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From elevenlabs.io -> Profile -> API Keys
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From recraft.ai -> API dashboard
RECRAFT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
